/* 卡片样式 */
.point-card.data-v-1cf27b2a {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
}
.point-card.data-v-1cf27b2a:active {
  transform: scale(0.98);
  background-color: #fafafa;
}
.point-card .card-body.data-v-1cf27b2a {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.point-card .info-left.data-v-1cf27b2a {
  flex: 1;
}
.point-card .info-left .title-row.data-v-1cf27b2a {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.point-card .info-left .title-row .title.data-v-1cf27b2a {
  font-size: 34rpx;
  font-weight: bold;
  color: #303133;
}
.point-card .info-left .address-text.data-v-1cf27b2a {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 18rpx;
  line-height: 1.4;
}
.point-card .info-left .distance-meta.data-v-1cf27b2a {
  font-size: 24rpx;
}
.point-card .info-left .distance-meta .dist-val.data-v-1cf27b2a {
  color: #fa3534;
  font-weight: bold;
}
.point-card .info-left .distance-meta .dist-val.in-range.data-v-1cf27b2a {
  color: #19be6b;
}
.point-card .info-left .distance-meta .radius-tip.data-v-1cf27b2a {
  color: #c0c4cc;
  margin-left: 8rpx;
}
.point-card .action-right.data-v-1cf27b2a {
  margin-left: 30rpx;
}
.point-card .action-right .go-btn.data-v-1cf27b2a {
  width: 80rpx;
